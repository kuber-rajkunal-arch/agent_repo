config {
  type: "table",
  schema: "AeroSrc",
  name: "aircraft_business_logic",
  description: "Translates complex procedural business logic for aircraft maintenance into a declarative SQL model. Calculates risk scores, z-scores for vibration, and determines operational status.",
  tags: ["maintenance", "risk_score", "aero"],
  assertions: {
    uniqueKey: ["FLIGHT_ID", "MAINT_EVENT_ID"]
  }
}

WITH
  stats AS (
    SELECT
      f.FLIGHT_ID,
      f.AIRCRAFT_ID,
      f.ENGINE_TEMP,
      f.FATIGUE_INDEX,
      f.FLIGHT_TS,
      CAST(JSON_VALUE(f.TELEMETRY_JSON, '''$.engine.vibration''') AS FLOAT64) AS vib,
      m.MAINT_EVENT_ID,
      m.EVENT_START_TS,
      m.EVENT_END_TS,
      AVG(f.ENGINE_TEMP) OVER (PARTITION BY f.AIRCRAFT_ID) AS avg_temp,
      STDDEV(CAST(JSON_VALUE(f.TELEMETRY_JSON, '''$.engine.vibration''') AS FLOAT64)) OVER (PARTITION BY f.AIRCRAFT_ID) AS stddev_vib
    FROM
      ${ref("Flight")} AS f
      JOIN ${ref("Maintenance")} AS m
      ON f.AIRCRAFT_ID = m.AIRCRAFT_ID
    WHERE
      f.FLIGHT_TS > TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 365 DAY)
  ),
  derived_metrics AS (
    SELECT
      FLIGHT_ID,
      AIRCRAFT_ID,
      MAINT_EVENT_ID,
      ( (ENGINE_TEMP / avg_temp) * 50 + FATIGUE_INDEX * 50 ) AS RISK_SCORE,
      (
        (vib - AVG(vib) OVER (PARTITION BY AIRCRAFT_ID)) / NULLIF(stddev_vib, 0)
      ) AS VIB_Z_SCORE,
      DATE_DIFF(EVENT_END_TS, EVENT_START_TS, 'DAY') as day_delta
    FROM
      stats
  )
SELECT
  dm.FLIGHT_ID,
  dm.AIRCRAFT_ID,
  dm.MAINT_EVENT_ID,
  dm.RISK_SCORE,
  dm.VIB_Z_SCORE,
  CASE
    WHEN dm.RISK_SCORE > 80 THEN 'CRITICAL_AOG_REQUIRED'
    WHEN dm.VIB_Z_SCORE > 2 THEN 'VIBRATION_ANOMALY_DETECTED'
    ELSE 'STABLE'
  END AS OP_STATUS,
  CASE
    WHEN dm.day_delta < 0 THEN 'ERR_NEG'
    ELSE 'PASS'
  END AS INTEGRITY_FLAG,
  CURRENT_TIMESTAMP() AS LOAD_TS
FROM
  derived_metrics AS dm