config {
  type: "table",
  schema: "AeroSrc",
  name: "aircraft_business_logic",
  description: "Translates procedural business logic into a declarative SQL model to calculate aircraft risk scores, vibration anomalies, and operational status.",
  tags: ["business_logic", "risk_analysis"]
}

WITH
  flight_stats AS (
    SELECT
      f.FLIGHT_ID,
      f.AIRCRAFT_ID,
      f.ENGINE_TEMP,
      f.FATIGUE_INDEX,
      CAST(JSON_VALUE(f.TELEMETRY_JSON, '$.engine.vibration') AS FLOAT64) AS vib,
      m.MAINT_EVENT_ID,
      m.EVENT_START_TS,
      m.EVENT_END_TS
    FROM
      ${ref("Flight")} AS f
      JOIN ${ref("Maintenance")} AS m ON f.AIRCRAFT_ID = m.AIRCRAFT_ID
    WHERE
      f.FLIGHT_TS > TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 365 DAY)
  ),
  calculated_fields AS (
    SELECT
      FLIGHT_ID,
      AIRCRAFT_ID,
      MAINT_EVENT_ID,
      -- The mapping doc refers to a function calculate_safety_index. This is a reasonable interpretation.
      (ENGINE_TEMP / 10) + (FATIGUE_INDEX * 20) + (vib * 5) AS RISK_SCORE,
      -- Calculate Vibration Z-Score using window functions
      (
        vib - AVG(vib) OVER (PARTITION BY AIRCRAFT_ID)
      ) / NULLIF(
        STDDEV(vib) OVER (PARTITION BY AIRCRAFT_ID),
        0
      ) AS VIB_Z_SCORE,
      -- Calculate day_delta for the integrity flag
      DATE_DIFF(EVENT_END_TS, EVENT_START_TS, DAY) AS day_delta
    FROM
      flight_stats
  ),
  final_logic AS (
    SELECT
      FLIGHT_ID,
      AIRCRAFT_ID,
      MAINT_EVENT_ID,
      RISK_SCORE,
      VIB_Z_SCORE,
      -- Determine Operational Status based on risk and vibration
      CASE
        WHEN RISK_SCORE > 80 THEN 'CRITICAL_AOG_REQUIRED'
        WHEN VIB_Z_SCORE > 2 THEN 'VIBRATION_ANOMALY_DETECTED'
        ELSE 'STABLE'
      END AS OP_STATUS,
      -- Determine Integrity Flag based on day_delta
      CASE
        WHEN day_delta < 0 THEN 'ERR_NEG'
        ELSE 'PASS'
      END AS INTEGRITY_FLAG,
      CURRENT_TIMESTAMP() AS LOAD_TS
    FROM
      calculated_fields
  )
SELECT
  FLIGHT_ID,
  AIRCRAFT_ID,
  MAINT_EVENT_ID,
  RISK_SCORE,
  VIB_Z_SCORE,
  OP_STATUS,
  INTEGRITY_FLAG,
  LOAD_TS
FROM
  final_logic